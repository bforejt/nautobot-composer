# =============================================================================
# Nautobot Docker Compose — Environment Variables
# =============================================================================
# This file documents all available environment variables with their defaults.
# Run ./setup.sh to generate a .env file with random secrets automatically.
#
# To create .env manually instead:
#   cp env.example .env
#   # Then fill in NAUTOBOT_SECRET_KEY, passwords, and API token.
# =============================================================================

# ---------------------------------------------------------------------------
# Nautobot Core
# ---------------------------------------------------------------------------

# Django secret key — must be unique per deployment. Auto-generated by setup.sh.
# Generate manually: python3 -c "from secrets import token_urlsafe; print(token_urlsafe(64))"
#NAUTOBOT_SECRET_KEY=

# Comma-separated list of hostnames/IPs that Nautobot will respond to.
# Use '*' for development; set to your FQDN(s) in production.
NAUTOBOT_ALLOWED_HOSTS=*

# Set to True only for development/debugging.
NAUTOBOT_DEBUG=False

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
NAUTOBOT_LOG_LEVEL=INFO

# Expose Prometheus metrics at /metrics
NAUTOBOT_METRICS_ENABLED=True

# Unlimited API page size (0 = no limit)
NAUTOBOT_MAX_PAGE_SIZE=0

# Hide UI elements the user doesn't have permission to access.
NAUTOBOT_HIDE_RESTRICTED_UI=True

# Opt out of anonymous installation metrics.
NAUTOBOT_INSTALLATION_METRICS_ENABLED=False

# ---------------------------------------------------------------------------
# PostgreSQL Database
# ---------------------------------------------------------------------------
POSTGRES_DB=nautobot
POSTGRES_USER=nautobot
# Auto-generated by setup.sh. Set a strong password if creating .env manually.
#POSTGRES_PASSWORD=

# NAUTOBOT_DB_* must match the POSTGRES_* values above.
NAUTOBOT_DB_NAME=nautobot
NAUTOBOT_DB_USER=nautobot
NAUTOBOT_DB_HOST=db
NAUTOBOT_DB_PORT=5432
NAUTOBOT_DB_ENGINE=django.db.backends.postgresql

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
NAUTOBOT_REDIS_HOST=redis
NAUTOBOT_REDIS_PORT=6379
NAUTOBOT_REDIS_PASSWORD=
NAUTOBOT_REDIS_SSL=False

# ---------------------------------------------------------------------------
# Superuser — Created on First Start
# ---------------------------------------------------------------------------
# Set NAUTOBOT_CREATE_SUPERUSER=true to auto-create an admin account.
NAUTOBOT_CREATE_SUPERUSER=true
NAUTOBOT_SUPERUSER_NAME=admin
NAUTOBOT_SUPERUSER_EMAIL=admin@example.com
# Auto-generated by setup.sh. Set manually if not using setup.sh.
#NAUTOBOT_SUPERUSER_PASSWORD=
#NAUTOBOT_SUPERUSER_API_TOKEN=

# ---------------------------------------------------------------------------
# NAPALM (optional — used by some Apps for device interaction)
# ---------------------------------------------------------------------------
NAPALM_USERNAME=
NAPALM_PASSWORD=
NAPALM_TIMEOUT=30

# ---------------------------------------------------------------------------
# Celery
# ---------------------------------------------------------------------------
# By default Celery uses the same Redis instance as caching.
# Override only if you need a separate broker:
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/0
